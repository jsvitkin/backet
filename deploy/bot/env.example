DISCORD_TOKEN=replace-with-github-secret-or-vm-secret
DISCORD_GUILD_ID=replace-with-your-guild-id

BACKET_BOT_BUNDLE=/srv/backet-bot/data/current
BACKET_SKIP_UPDATE_CHECK=1

# Enable the llama Compose profile only when bot-config.yaml uses answer_mode: llama-local.
COMPOSE_PROFILES=
LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server
BACKET_INSTALL_SPEC=
LLAMA_MODEL_RELATIVE_PATH=llama-3.2-3b-instruct-q4/model.gguf
LLAMA_MODEL_SHA256=
LLAMA_MODEL_URL=
