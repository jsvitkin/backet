DISCORD_TOKEN=replace-with-github-secret-or-vm-secret
DISCORD_GUILD_ID=replace-with-your-guild-id

BACKET_BOT_BUNDLE=/srv/backet-bot/data/current
BACKET_SKIP_UPDATE_CHECK=1
BACKET_BOT_LOG_QUESTION_TEXT=1

# Runtime quality profile. lite preserves the current low-resource behavior.
# rag-standard requires embedding support and can degrade with diagnostics.
# rag-quality requires embedding, reranker, and answer model services.
BACKET_RAG_PROFILE=lite
BACKET_MODEL_CACHE=/srv/backet-bot/models
BACKET_EMBEDDING_ENDPOINT=
BACKET_RERANKER_ENDPOINT=
BACKET_ANSWER_MODEL_ENDPOINT=
BACKET_LLAMA_ENDPOINT=http://llama:8080/completion

# Enable Compose profiles only for services you operate on this VM.
# Third-party hosted model APIs are not supported by this initial hosting slice.
COMPOSE_PROFILES=
BACKET_EMBEDDING_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-latest
BACKET_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
BACKET_RERANKER_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-latest
BACKET_RERANKER_MODEL=BAAI/bge-reranker-base
LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server
BACKET_INSTALL_SPEC=
LLAMA_MODEL_RELATIVE_PATH=llama-3.2-3b-instruct-q4/model.gguf
LLAMA_MODEL_SHA256=
LLAMA_MODEL_URL=
