{
  "schema_version": 1,
  "cases": [
    {
      "id": "learn-obfuscate-advancement",
      "description": "A question about learning Obfuscate needs advancement or acquisition evidence, not a character page that happens to contain the word learn and the discipline name.",
      "difficulty": "easy",
      "command": "rules.ask",
      "question": "how do I learn obfuscate",
      "expected_answerable": true,
      "required_planner_terms": [
        "obfuscate",
        "advancement"
      ],
      "expected_intents": [
        "advancement"
      ],
      "expected_sources": [
        {
          "source_type": "rules",
          "text_contains": "Obfuscate"
        }
      ],
      "forbidden_sources": [
        {
          "text_contains": "learn a lesson about myself"
        }
      ],
      "forbidden_answer_contains": [
        "learn a lesson about myself"
      ]
    },
    {
