          "kindred"
        ]
      },
      "expected_intents": [
        "targeting"
      ],
      "expected_sources": [
        {
          "source_type": "rules",
          "text_contains": "Dementation"
        }
      ],
      "forbidden_sources": [
        {
          "text_contains": "Malkavians do not advertise their use of Obfuscate"
        }
      ],
      "forbidden_answer_contains": [
